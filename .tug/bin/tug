#!/usr/bin/env bash
# tug — minimal Ralph-style loop driver.
#
# Subcommands:
#   tug once                Run a single iteration (HITL — watch, intervene).
#   tug afk <N>             Run up to N iterations (capped). Exits early on COMPLETE sentinel.
#   tug status              Print the current PRD/progress state.
#
# Conventions (per the working dir of the project being driven):
#   PRD.md                  The mutable spec. Tasks marked [ ] / [~] / [x].
#   progress.txt            Per-iteration diary. Appended each loop. Committed.
#   .tug/config.sh          Optional override of model/permission/sentinel/timeout.
#
# Sentinel: agent must echo  <promise>COMPLETE</promise>  on stdout when done.
#           To signal a hard external block, agent echoes  <promise>BLOCKED reason="..."</promise>.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case "${1:-}" in
  once)
    exec "$SCRIPT_DIR/tug-once.sh" "${@:2}"
    ;;
  afk)
    if [ -z "${2:-}" ]; then
      echo "usage: tug afk <iterations>"
      exit 1
    fi
    exec "$SCRIPT_DIR/tug-afk.sh" "$2"
    ;;
  status)
    if [ -f plans/prd.json ]; then
      echo "=== plans/prd.json — task counts ==="
      python3 -c "
import json
prd = json.load(open('plans/prd.json'))
tasks = prd.get('tasks', [])
passing = sum(1 for t in tasks if t.get('passes') is True)
failing = sum(1 for t in tasks if t.get('passes') is False)
print(f'  total      : {len(tasks)}')
print(f'  passing    : {passing}')
print(f'  failing    : {failing}')
print()
print('=== failing tasks ===')
for t in tasks:
    if t.get('passes') is False:
        print(f\"  [ ] {t['id']:40s} {t.get('title','')[:60]}\")
"
      echo
    fi
    if [ -f plans/progress.txt ]; then
      echo "=== plans/progress.txt (tail) ==="
      tail -25 plans/progress.txt
      echo
    fi
    echo "=== orchestrator state ==="
    echo "  TUG_PIN_TASK = ${TUG_PIN_TASK:-<unset>}"
    if [ -f .tug/batch_context.md ]; then
      echo "  batch_context.md: present ($(wc -l < .tug/batch_context.md) lines)"
    else
      echo "  batch_context.md: absent"
    fi
    echo "  recent .tug/logs/:"
    ls -t .tug/logs/ 2>/dev/null | head -5 | sed 's/^/    /'
    ;;
  ""|-h|--help|help)
    awk 'NR>=2 && NR<=12 { sub(/^# ?/, ""); print }' "$0"
    ;;
  *)
    echo "unknown subcommand: $1"
    echo "try: tug help"
    exit 1
    ;;
esac
