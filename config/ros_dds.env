# isaac-sim-mcp — canonical ROS 2 / DDS environment for the SIM stack.
# Sourced by scripts/sim_bringup.sh so the UR driver joins the SAME DDS vendor
# + interface config as the MCP consumer (ros-mcp-server).
#
# WHY THIS FILE EXISTS (2026-05-27)
#   move_home(mode='sim') failed with "UR robot driver isn't running" while
#   control_gripper(mode='sim') worked. Root cause: the driver was launched
#   with the shell default ROS_LOCALHOST_ONLY=0 (+ FastDDS), but the consumer
#   (ros-mcp-server) pins ROS_LOCALHOST_ONLY=1 + CycloneDDS. ROS 2 requires
#   ROS_LOCALHOST_ONLY to be IDENTICAL on every node sharing a domain — a mixed
#   1/0 setup gives one-way discovery: a plain topic *publish* (gripper ->
#   Isaac) still flows, but the consumer->driver direction (FollowJointTrajectory
#   action discovery + the /joint_states subscription move_home needs) never
#   matches, so wait_for_server() times out -> "action server not available".
#
#   Proven empirically (daemon-free rclpy ActionClient against the live driver):
#     Cyclone + localhost_only=1  (consumer's real env)  -> SERVER_NOT_FOUND
#     Cyclone + localhost_only=0                          -> SERVER_FOUND
#     FastDDS + localhost_only=0  (driver's old env)      -> SERVER_FOUND
#   i.e. localhost_only is the decisive knob; cross-vendor discovery works once
#   it matches. We standardize the whole sim stack on Cyclone + localhost_only=1.
#
# KEEP IN SYNC WITH THE CONSUMER:
#   mcp-client-example/mcp_config*.json  ros-mcp-server.env.{ROS_DOMAIN_ID,
#                                        ROS_LOCALHOST_ONLY}
#   ros-mcp-server/server_mode2.py       os.environ.setdefault(RMW_IMPLEMENTATION,
#                                        CYCLONEDDS_URI)
#
# This file only touches ROS2/DDS env (interfaces + discovery). The driver's
# link to URSim/the robot is plain TCP and is unaffected by ROS_LOCALHOST_ONLY.

# Domain — MUST match every ROS client. Respects an already-exported value.
export ROS_DOMAIN_ID="${ROS_DOMAIN_ID:-7}"

# Interface isolation — MUST match the consumer (single-host, loopback only).
export ROS_LOCALHOST_ONLY=1

# DDS vendor — homogeneous with the consumer + Isaac (no cross-vendor actions).
export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# Cyclone profile (AllowMulticast off, SharedMemory off) — self-contained copy
# next to this file, mirroring the consumer's cyclonedds_local.xml.
_ISAAC_DDS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export CYCLONEDDS_URI="file://${_ISAAC_DDS_DIR}/cyclonedds.xml"
unset _ISAAC_DDS_DIR

# Standalone gripper colcon overlay (2026-06-25). onrobot_rg2_sim_control is now a SEPARATE colcon
# package in ~/Desktop/ros2_ws (peer of ur_robot_driver), NOT embedded in ros-mcp-server. Source it
# here so everything that sources this env can import onrobot_rg2_sim_control.rg2_arc (config.py's
# W-dynamic grasp depth) and resolve the gripper backend/driver via the package share dir. Mirrors
# a4500's ROS_WS_SETUP in prismatic-manipulation/config/ros_env.sh. Guarded: if the overlay is
# absent the import simply fails LOUD downstream (config.grasp_offset_mm), never a silent wrong-depth.
_RG2_OVERLAY="${ROS_WS_SETUP:-$HOME/Desktop/ros2_ws/install/setup.bash}"
if [ -f "$_RG2_OVERLAY" ]; then source "$_RG2_OVERLAY"; fi
unset _RG2_OVERLAY
