                    double3 xformOp:translate = (4.742500, -2.380000, 1.400000)
                    float3 xformOp:scale = (3.307500, 1.190000, 0.350000)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                }
                def Cube "box_017" (
