#usda 1.0
(
    defaultPrim = "Root"
    metersPerUnit = 1
    upAxis = "Z"
)

# BOX-COMPOUND collider overlay for base1 (step-2 collider-only test). References the step-1 split
# geometry and swaps the SDF-on-mesh collider for 22 analytic Cube box primitives. NO physics
# material (PhysX defaults, matching the working SDF run) — isolates the COLLIDER. approximation="none"
# stops add_objects authoring a stray SDF collider on the mesh. Box coords are in the geometry's native
# cm frame (inherit the mesh xformOp:scale=0.01 -> metres), so they align exactly.

def Xform "Root" (
    prepend references = @./base1.usda@
)
{
    over "base1"
    {
        over "base1" (
            prepend apiSchemas = ["PhysicsRigidBodyAPI"]
        )
        {
            uniform token physics:approximation = "none"
            bool physics:rigidBodyEnabled = 1
            def Scope "collisions"
            {
                def Cube "box_000" (
                    prepend apiSchemas = ["PhysicsCollisionAPI", "PhysxCollisionAPI"]
                )
                {
                    double size = 2
                    bool physics:collisionEnabled = 1
                    float physxCollision:restOffset = 0
                    double3 xformOp:translate = (0.000000, 0.000000, -1.575000)
                    float3 xformOp:scale = (8.050000, 8.050000, 0.175000)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                }
                def Cube "box_001" (
                    prepend apiSchemas = ["PhysicsCollisionAPI", "PhysxCollisionAPI"]
                )
                {
                    double size = 2
                    bool physics:collisionEnabled = 1
                    float physxCollision:restOffset = 0
                    double3 xformOp:translate = (0.000000, -7.000000, -0.175000)
                    float3 xformOp:scale = (8.050000, 1.050000, 1.225000)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                }
                def Cube "box_002" (
                    prepend apiSchemas = ["PhysicsCollisionAPI", "PhysxCollisionAPI"]
                )
                {
                    double size = 2
                    bool physics:collisionEnabled = 1
                    float physxCollision:restOffset = 0
                    double3 xformOp:translate = (0.000000, -7.595000, 1.400000)
                    float3 xformOp:scale = (8.050000, 0.455000, 0.350000)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                }
                def Cube "box_003" (
                    prepend apiSchemas = ["PhysicsCollisionAPI", "PhysxCollisionAPI"]
                )
                {
                    double size = 2
                    bool physics:collisionEnabled = 1
                    float physxCollision:restOffset = 0
                    double3 xformOp:translate = (-4.742500, -6.545000, 1.400000)
                    float3 xformOp:scale = (3.307500, 0.595000, 0.350000)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                }
                def Cube "box_004" (
                    prepend apiSchemas = ["PhysicsCollisionAPI", "PhysxCollisionAPI"]
                )
                {
                    double size = 2
                    bool physics:collisionEnabled = 1
                    float physxCollision:restOffset = 0
                    double3 xformOp:translate = (-5.845000, -3.570000, 0.175000)
                    float3 xformOp:scale = (2.205000, 2.380000, 1.575000)
